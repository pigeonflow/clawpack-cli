{
  "name": "@clawpack/cli",
  "version": "0.10.0",
  "description": "CLI for ClawPack — the agent registry",
  "bin": {
    "clawpack": "bin/clawpack"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.0.0",
    "commander": "^13.0.0",
    "figlet": "^1.10.0",
    "glob": "^11.0.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.0.0",
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "openclaw",
    "agent",
    "registry",
    "clawpack"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pigeonflow/clawpack-cli.git"
  },
  "homepage": "https://clawpack.io",
  "bugs": {
    "url": "https://github.com/pigeonflow/clawpack-cli/issues"
  }
}
